    "# integrate x**2 from 0 to 1\n",
    "import sympy as sp\n",
    "\n",
    "x = sp.Symbol(\"x\")\n",
    "integrand = x**2\n",
    "area = sp.integrate(integrand, (x, 0, 1))\n",
    "print(f\"Area under the curve: {area}\")"
   ]
